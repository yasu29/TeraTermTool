; ==========================================================
; Main.ttl - ログイン後処理マクロ
; ==========================================================

; 接続が完了して安定するまでわずかに待機
pause 1

; --- 1. ログ出力設定 ---
getdir current_dir
log_dir = current_dir
strconcat log_dir '\log'

; フォルダ存在確認
folderexist log_dir result
if result = 0 then
    mkdir log_dir
endif

strtime timestr "%Y%m%d-%H%M%S"
; ファイル名に日時を付与（※本体起動のためparam1等の引数は不要になりました）
sprintf2 log_file "%s%s_%s.log" log_dir host timestr

; ログ取得開始（0:標準, 1:追記）
logopen log_file 0 1

; --- 2. プロンプトの待機とコマンド実行 ---
; 一般的なプロンプト記号のいずれかが出るまで待つ
wait '$' '#' '%'

; プロンプトの装飾設定（色付けなど）
sendln 'export PS1="[\t][\[\e[1;32m\]\u\[\e[0;39m\]@\[\e[1;36m\]\h\[\e[0;39m\]]% "'

; 以降、装飾後のプロンプト終了文字「]」を待機してコマンドを送出
wait ']'
sendln 'id; uname -n'

wait ']'
sendln 'date'

; マクロのみ終了（Tera Termのウィンドウはそのまま残ります）
end
