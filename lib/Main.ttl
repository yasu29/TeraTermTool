; ==========================================================
; Main.ttl - ログイン後処理マクロ
; ==========================================================

; --- プロンプト定義 ---
prompt_user = '$'
prompt_root = '#'
prompt_other = '%'

; --- 0. 引数の受け取り ---
hostname = param2
username = param3
password = param4


; --- 1. 接続処理 ---
; connectコマンド用の文字列を組み立て
; 例: 192.168.1.1:22 /ssh /2 /auth=password /user=root /passwd=pw
sprintf2 conn_cmd '%s:22 /ssh /2 /auth=password /user=%s /passwd=%s' hostname username password

connect conn_cmd


; 接続に失敗した（またはキャンセルした）場合の処理
if result != 2 then
    ; 接続が「通信中(2)」でない場合は終了
    end
endif

; --- 2. ログ出力設定 ---
getdir current_dir
log_dir = current_dir
strconcat log_dir '\..\log'

; フォルダ存在確認
filesearch log_dir
if result == 0 then
    foldercreate log_dir
endif

gettime timestr "%Y%m%d-%H%M%S"
; ファイル名にIPアドレスと日時を付与
sprintf2 log_file "%s\%s_%s.log" log_dir hostname timestr

; ログ取得開始（0:標準, 1:追記）
logopen log_file 0 1

; --- 3. プロンプトの待機とコマンド実行 ---
; タイムアウトを設定
timeout = 10

; 一般的なプロンプト記号のいずれかが出るまで待つ
wait prompt_user prompt_root prompt_other

if result == 0 then
    messagebox "プロンプトの待機中にタイムアウトしました。" "Error"
    end
endif

; プロンプトの装飾設定
break_count = 3
call s_break_line_flex
sendln 'export PS1="[\t][\u@\h]% "'

wait prompt_user prompt_root prompt_other
call s_break_line_flex
sendln 'id; uname -n'

wait prompt_user prompt_root prompt_other
call s_break_line_flex
sendln 'date'

wait prompt_user prompt_root prompt_other
call s_break_line_flex

; マクロのみ終了（Tera Termのウィンドウはそのまま残ります）
end

; ============================================================
; サブルーチン: 改行挿入
; ============================================================

:s_break_line_flex
    for i 1 break_count
        sendln
    next

return
