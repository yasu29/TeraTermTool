; ==========================================================
; Main.ttl - ログイン後処理マクロ
; ==========================================================

; 接続が完了して安定するまでわずかに待機
pause 1

; --- 1. ログ出力設定 ---
getdir current_dir
log_dir = current_dir
strconcat log_dir '\..\log'

; フォルダ存在確認
filesearch log_dir
if result == 0 then
    foldercreate log_dir
endif

gettime timestr "%Y%m%d-%H%M%S"
; ファイル名に日時を付与（※本体起動のためparam1等の引数は不要になりました）
sprintf2 log_file "%s\console_%s.log" log_dir timestr

; ログ取得開始（0:標準, 1:追記）
logopen log_file 0 1

; --- 2. プロンプトの待機とコマンド実行 ---
; 一般的なプロンプト記号のいずれかが出るまで待つ
wait '$' '#' '%'

; プロンプトの装飾設定（色付けなど）
sendln 'export PS1="[\t][\u@\h]% "'

; 以降、装飾後のプロンプト終了文字「]」を待機してコマンドを送出
wait ']'
sendln 'id; uname -n'

wait ']'
sendln 'date'

; マクロのみ終了（Tera Termのウィンドウはそのまま残ります）
end
